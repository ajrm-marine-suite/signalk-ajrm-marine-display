{
  "name": "signalk-ajrm-marine-display",
  "version": "0.5.26",
  "description": "Chart, traffic, and vessel-status display for the AJRM Marine Suite.",
  "main": "plugin/index.js",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "lint:check": "biome lint src",
    "test": "npm run lint:check && npm run build && node scripts/validate-scaffold.js && node --test && node --check plugin/index.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-category-ais",
    "ais",
    "display",
    "signal-k",
    "signalk",
    "ajrm-marine-suite",
    "marine",
    "navigation"
  ],
  "author": "Anthony McDonald, with assistance from William McAusland",
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajrm-marine-suite/signalk-ajrm-marine-display.git"
  },
  "bugs": {
    "url": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-display/issues"
  },
  "homepage": "https://github.com/ajrm-marine-suite/signalk-ajrm-marine-display#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "plugin",
    "public",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "dependencies": {
    "@protomaps/basemaps": "^5.5.1",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "labelgun": "^6.1.0",
    "leaflet": "^1.9.4",
    "leaflet-easybutton": "^2.4.0",
    "lodash": "^4.17.21",
    "nosleep.js": "^0.12.0",
    "protomaps-leaflet": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "sass-embedded": "^1.93.2",
    "vite": "^7.1.7"
  },
  "signalk-plugin-enabled-by-default": true,
  "signalk": {
    "displayName": "AJRM Marine Display",
    "appIcon": "./assets/icon-120.png"
  }
}
